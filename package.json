{
  "name": "vouch",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "seed": "tsx src/store/seed.ts",
    "import": "tsx src/notion/import.ts",
    "import:all": "tsx src/notion/import.ts --all",
    "reset:notion": "tsx scripts/reset-notion.ts",
    "wipe:channel": "tsx scripts/wipe-channel.ts",
    "demo": "tsx scripts/wipe-channel.ts && rm -f vouch.db && tsx src/store/seed.ts && tsx scripts/reset-notion.ts && tsx scripts/replay.ts fixtures/demo-buildup.json --delay 1500 && tsx src/slack/app.ts",
    "mcp": "tsx src/mcp-server/index.ts",
    "inspect": "npx @modelcontextprotocol/inspector tsx src/mcp-server/index.ts",
    "eval": "tsx src/reconciliation/eval.ts",
    "slack": "tsx src/slack/app.ts",
    "replay": "tsx scripts/replay.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@slack/bolt": "^4.7.3",
    "better-sqlite3": "^11.5.0",
    "openai": "^6.45.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@modelcontextprotocol/inspector": "^0.22.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
