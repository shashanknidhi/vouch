{
  "display_information": {
    "name": "Vouch",
    "description": "Keeps your docs honestly fresh — catches decisions in Slack, gets a human to vouch, writes them back with provenance.",
    "background_color": "#1a1d21"
  },
  "features": {
    "bot_user": {
      "display_name": "vouch",
      "always_online": true
    },
    "slash_commands": [
      {
        "command": "/vouch",
        "description": "Ask what's stale, or why the doc says what it says",
        "usage_hint": "status | why <section>",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "user": ["search:read.public"],
      "bot": [
        "channels:history",
        "channels:read",
        "chat:write",
        "chat:write.customize",
        "im:write",
        "users:read",
        "commands"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": ["message.channels"]
    },
    "interactivity": {
      "is_enabled": true
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}
